{
    "name": "igor-php/igor-php",
    "description": "The faithful assistant for your FrankenPHP Workers.",
    "keywords": ["frankenphp", "linter", "static-analysis", "symfony", "worker"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kevin MARTINS",
            "email": "kevin.martins@me.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/process": "^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/http-kernel": "^6.0 || ^7.0",
        "symfony/http-foundation": "^6.0 || ^7.0",
        "symfony/service-contracts": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "IgorPhp\\IgorBundle\\": "src/php/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IgorPhp\\IgorBundle\\Tests\\": "tests/php/"
        }
    },
    "bin": [
        "bin/igor-php"
    ]
}
